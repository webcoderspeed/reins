{
  "name": "reins",
  "version": "1.0.0",
  "description": "Rein in your async. Structured concurrency and cancellation for JavaScript & TypeScript — scoped tasks, automatic cancellation, timeouts. No DSL, no generators. Just async/await.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "structured-concurrency",
    "concurrency",
    "cancellation",
    "abortcontroller",
    "abortsignal",
    "nursery",
    "scope",
    "async",
    "await",
    "promise",
    "timeout",
    "task",
    "trio",
    "coroutinescope",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://github.com/webcoderspeed/reins#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webcoderspeed/reins.git"
  },
  "bugs": {
    "url": "https://github.com/webcoderspeed/reins/issues"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "author": "webcoderspeed"
}
